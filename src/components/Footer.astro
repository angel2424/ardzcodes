---
const year = new Date().getFullYear()
---

<footer class="bg-brand-100 dark:bg-slate-900" data-footer>
  <div class="mx-auto max-w-7xl px-8 py-12">
    <h2 class="font-heading text-4xl font-medium text-slate-900 dark:text-slate-100">
      ardzcodes
    </h2>

    <div class="mt-8 flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
      <p class="text-sm font-light text-slate-600 dark:text-slate-400">
        Copyright 2022 - {year} © ardzcodes. All rights reserved
      </p>

      <div class="flex items-center gap-4">
        <a
          class="text-slate-900 transition duration-300 hover:text-brand-500 dark:text-slate-100"
          href="https://www.instagram.com/a.rdzcodes24/"
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
        >
          <i class="fa-brands fa-instagram text-xl" aria-hidden="true"></i>
        </a>
        <a
          class="text-slate-900 transition duration-300 hover:text-brand-500 dark:text-slate-100"
          href="/"
          aria-label="Facebook"
        >
          <i class="fa-brands fa-facebook text-xl" aria-hidden="true"></i>
        </a>
        <a
          class="text-slate-900 transition duration-300 hover:text-brand-500 dark:text-slate-100"
          href="https://github.com/angel2424"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <i class="fa-brands fa-github text-xl" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
