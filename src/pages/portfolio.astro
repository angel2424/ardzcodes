---
import BaseLayout from '../layouts/BaseLayout.astro'
import Projects from '../components/landing/Projects.astro'
import type { Lang } from '../i18n/translations'
import { useTranslations } from '../i18n/translations'

const lang = (Astro.currentLocale ?? 'en') as Lang
const t = useTranslations(lang)
---

<BaseLayout title="ardzcodes - Portfolio" description="Portfolio projects built by ardzcodes">
  <main class="relative z-10">
    <section class="mx-auto max-w-7xl px-8 pt-40 pb-0 lg:pt-64">
      <h1 class="text-5xl font-extrabold text-slate-900 dark:text-slate-100 lg:text-6xl">Portfolio</h1>
      <p class="mt-3 text-xl font-light leading-snug tracking-wide text-slate-600 dark:text-slate-300">
        {t.portfolio.text}
      </p>
    </section>

    <Projects showAll={true} showTitle={false} />
  </main>
</BaseLayout>
